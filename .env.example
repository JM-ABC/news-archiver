# ── 필수 ──────────────────────────────────────────────
# Google Gemini API 키 (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion (선택 — 둘 중 하나만 설정해도 됨) ──────────
# Notion Integration 토큰 (https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# [방법 A] Database ID — Notion DB URL에서 복사
#   예) https://notion.so/workspace/abc123def456... → abc123def456...
NOTION_DATABASE_ID=

# [방법 B] 단일 페이지 ID — 기존 페이지에 날짜별로 추가
#   예) https://notion.so/workspace/페이지제목-abc123... → abc123...
NOTION_PAGE_ID=
